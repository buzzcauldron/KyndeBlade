  BeatId: GreenChapelChallenge
  Text: 'I am the Knight of the Green Chapel. I offer thee a game: strike me once,
    and in a year and a day I shall return the blow. Dost thou accept the covenant?'
  SpeakerName: The Green Knight
  Portrait: {fileID: 0}
  Choices:
  - Text: I accept. I will meet thee at the Green Chapel.
    IsCorrectChoice: 1
  - Text: I refuse. I will not play thy game.
    IsCorrectChoice: 0
  - Text: I flee. This is no place for me.
    IsCorrectChoice: 0
  VisionIndex: 0
