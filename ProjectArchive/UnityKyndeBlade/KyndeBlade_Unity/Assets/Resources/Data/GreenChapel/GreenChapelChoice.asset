  BeatId: GreenChapelChallenge
  Text: "I am the Knyght of the Grene Chapel. I offre thee a pley: smyte me ones,
    and in a yeer and a day I shal quyte the stroke. Woltow holden the covenant?"
  SpeakerName: The Green Knight
  Portrait: {fileID: 0}
  Choices:
  - Text: I acorde. I shal meten thee at the Grene Chapel.
    IsCorrectChoice: 1
    TransitionToLocationId: 
    AssociatedSin: 0
    NextDialogueBeat: {fileID: 0}
  - Text: I refusen. I nil pleyen thy game.
    IsCorrectChoice: 0
    TransitionToLocationId: 
    AssociatedSin: 1
    NextDialogueBeat: {fileID: 0}
  - Text: I fleen. Hier is no stede for me.
    IsCorrectChoice: 0
    TransitionToLocationId: 
    AssociatedSin: 4
    NextDialogueBeat: {fileID: 0}
  VisionIndex: 0
