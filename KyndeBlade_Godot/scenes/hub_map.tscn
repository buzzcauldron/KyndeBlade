[node name="FlavorText" type="Label" parent="FlavorPanel/FVBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(480, 0)
layout_mode = 2
text = "A fair feeld ful of folke… (slice flavor)

You step toward Fair Field. False waits in the encounter ahead."
autowrap_mode = 3

